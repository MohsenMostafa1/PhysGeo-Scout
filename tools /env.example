# Mohsen Research Agent - Environment Variables
# Copy this to .env and fill in your keys.
# APIs with no key still work (free tier or no-auth).

# Reddit (free, register at https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=MohsenResearchAgent/1.0

# GitHub (optional, for higher rate limits: https://github.com/settings/tokens)
GITHUB_TOKEN=

# Discord Webhook (optional, for alerts: https://discord.com/developers)
DISCORD_WEBHOOK_URL=

# Semantic Scholar (optional, for higher limits: https://www.semanticscholar.org/product/api#api-key-form)
SEMANTIC_SCHOLAR_API_KEY=

# SerpAPI (optional, for Google Scholar: https://serpapi.com/)
SERPAPI_KEY=

# Google ADK
GOOGLE_API_KEY=

# LLM for CrewAI agents
OPENAI_API_KEY=
